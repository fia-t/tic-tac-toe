# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# firebase-admin service account keys - never commit these; scripts/setAdminClaim.js
# uses Application Default Credentials instead, see scripts/README.md
*serviceAccountKey*.json
*-firebase-adminsdk-*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
