# Скопіюйте цей файл у .env.local і підставте значення зі свого Firebase-проєкту
# (Project settings -> General -> Your apps -> SDK setup and configuration -> Config).
# Ці значення публічні (потрапляють у код браузера) - це нормально для Firebase Web SDK,
# доступ реально обмежують Firestore Security Rules, а не секретність цих полів.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Опційно - лише якщо у Firebase-проєкті увімкнено Google Analytics
# (значення виду G-XXXXXXXXXX). Без нього трекінг подій просто мовчки вимкнений.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Опційно - заповніть, лише якщо у Firestore створена НЕ стандартна база
# "(default)", а іменована (Firestore Database -> назва бази зверху сторінки,
# напр. "tic-tac-toe"). Якщо там написано "(default)" - лишіть це поле пустим.
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=
