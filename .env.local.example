# Скопіюйте цей файл у .env.local і підставте значення зі свого Firebase-проєкту
# (Project settings -> General -> Your apps -> SDK setup and configuration -> Config).
# Ці значення публічні (потрапляють у код браузера) - це нормально для Firebase Web SDK,
# доступ реально обмежують Firestore Security Rules, а не секретність цих полів.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Опційно - лише якщо у Firebase-проєкті увімкнено Google Analytics
# (значення виду G-XXXXXXXXXX). Без нього трекінг подій просто мовчки вимкнений.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Опційно - заповніть, лише якщо у Firestore створена НЕ стандартна база
# "(default)", а іменована (Firestore Database -> назва бази зверху сторінки,
# напр. "tic-tac-toe"). Якщо там написано "(default)" - лишіть це поле пустим.
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=

# --- SEO / сайт ---------------------------------------------------------
# Публічна production-адреса сайту БЕЗ слеша в кінці. Використовується для
# canonical URL, sitemap.xml, robots.txt, Open Graph і JSON-LD. Замініть на
# реальний домен перед публікацією.
NEXT_PUBLIC_SITE_URL=https://tictactoe-game.com

# Google Search Console - значення content з тега
# <meta name="google-site-verification" content="...">, який видає Search
# Console при підтвердженні власності через "HTML tag". Див. README.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Аналітика ------------------------------------------------------------
# Google Analytics 4 - Measurement ID виду G-XXXXXXXXXX з GA4 Admin -> Data Streams.
NEXT_PUBLIC_ANALYTICS_ID=

# Google Tag Manager - Container ID виду GTM-XXXXXXX.
NEXT_PUBLIC_GTM_ID=

# --- Реклама (AdsManager) --------------------------------------------------
# Який рекламний провайдер активний: adsense | nitropay | setupad | mediavine | none.
# "none" вимикає AdsManager повністю (за замовчуванням, поки нема реальних ID).
NEXT_PUBLIC_AD_PROVIDER=none

# Google AdSense - client ID виду ca-pub-XXXXXXXXXXXXXXXX і ID слотів з кабінету AdSense.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_INCONTENT=

# NitroPay - Site ID з кабінету NitroPay.
NEXT_PUBLIC_NITROPAY_SITE_ID=

# Setupad - Publisher ID з кабінету Setupad.
NEXT_PUBLIC_SETUPAD_PUBLISHER_ID=
