rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Той самий принцип, що й у firestore.rules: адмін визначається виключно
    // custom claim'ом admin: true, встановленим через scripts/setAdminClaim.js.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /themes/{themeId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
