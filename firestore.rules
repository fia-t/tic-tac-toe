rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Адмін визначається виключно custom claim'ом admin: true у ID token,
    // а не способом входу чи поштою. Claim можна встановити лише через
    // Firebase Admin SDK (scripts/setAdminClaim.js) - жоден клієнт чи
    // публічна Cloud Function не мають до цього доступу.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /themes/{themeId} {
      // Каталог фонів/скінів публічний на читання - його підвантажує будь-який
      // гравець (навіть до анонімного входу) ще до старту гри.
      allow read: if true;
      allow write: if isAdmin();
    }

    match /names/{nameId} {
      // Пул "цікавих" імен для рахунку над полем гри - так само публічний на
      // читання, як і теми, і так само редагується лише з адмінки.
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gameLogs/{logId} {
      // Запис лічильника зіграних партій дозволений будь-кому (навіть без
      // автентифікації - vs-AI режим повністю офлайн і не має анонімного
      // входу), але лише документ строго очікуваної форми. Читає/перелічує
      // лише адмінка (дашборд), звичайний гравець власні логи не бачить.
      allow create: if isValidGameLog(request.resource.data);
      allow read, list: if isAdmin();
      allow update, delete: if false;
    }

    match /rooms/{roomId} {

      // Читати кімнату може будь-хто автентифікований (анонімна авторизація теж
      // рахується) - потрібно, щоб гравець, який щойно перейшов за посиланням,
      // міг перевірити її статус ще до приєднання.
      allow get: if request.auth != null;

      // Перелік/пошук усіх кімнат заборонений - доступ лише за відомим roomId
      // (з посилання-запрошення), щоб чужі кімнати не можна було перебрати.
      allow list: if false;

      allow create: if request.auth != null && isValidNewRoom(request.resource.data);

      allow update: if request.auth != null &&
        (isExistingPlayer(resource.data, request.auth.uid) || isJoiningOpenSlot(resource.data, request.resource.data));

      allow delete: if false; // прибирання застарілих кімнат - через Firestore TTL, не з клієнта
    }
  }

  function isValidGameLog(data) {
    return data.mode in ['ai-easy', 'ai-hard', 'friend-3x3', 'friend-9x9']
      && data.outcome in ['win', 'lose', 'draw', 'x_win', 'o_win']
      && data.createdAt == request.time;
  }

  function isValidNewRoom(data) {
    return data.gameMode in ['3x3', '9x9']
      && data.status == 'waiting'
      && data.winner == null
      && data.players.X.uid == request.auth.uid
      && !('O' in data.players);
  }

  function isExistingPlayer(data, uid) {
    return (('X' in data.players) && data.players.X.uid == uid)
      || (('O' in data.players) && data.players.O.uid == uid);
  }

  // Дозволяє записати себе в кімнату лише на дійсно вільне місце O
  // (X уже зайнятий кимось іншим, O ще нікому не належить).
  function isJoiningOpenSlot(before, after) {
    return ('X' in before.players) && !('O' in before.players)
      && ('O' in after.players) && after.players.O.uid == request.auth.uid;
  }
}
